  "info": {
    "_postman_id": "b56eee18-3f7e-46ac-aa38-7723e449a2d0",
    "name": "Instacart Connect Post-Checkout API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Instacart Connect Post-Checkout API allows retailers to provide their customers with real-time order tracking and shopper interaction after an order has been placed. Retailers can use this API to build custom order status pages that display order details, live tracking information, and shopper communication. Customers can see updates while their order is being shopped and delivered, approve or decline item replacements suggested by shoppers, and communicate directly with shoppers via chat about replacements and additions.\n\nContact Support:\n Name: Instacart Connect Support",
      "type": "text/plain"
    }
  }
